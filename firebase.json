{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "singleProjectMode": true
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "target": "api",
    "public": "public",
    "rewrites": [
      {
        "source": "/.well-known/**",
        "function": {
          "functionId": "apiV2",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "function": {
          "functionId": "apiV2",
          "region": "us-central1"
        }
      }
    ]
  }
}
