OAUTH_SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAtwUzsLTI82Y+v3I5n/nC\n09ZG9sFH/9t5fwQjMkHVYuHviCAiCF//DpntZlQNgCSMygO1k313ULkMQnoUnWBS\nMv1u5aIrY5jVUJMcPSRljrUU6c5kPOwCpeqc0DTW55IlN1w1zh0w1bA6yC4tXzYz\nUHG5mKUWV155ZXAYcBm59o/cQDHRustOzghQIvaDCx1oBoOa5P3+bP+15OZygOfg\nEVJhTLAajYf+GFbHNseOuSWhOCy9F8jNczalh6azS+V/oqY6PCFlEhFKrI464z6s\n0HuZZa879TWJpc4y6WRrHEGHNc3QwvYLsd6xmL4DXRwAQyj9JAGtmwrVWnDWMHwb\nnwIDAQAB\n-----END PUBLIC KEY-----\n"

# OAuth client cleanup (L4 garbage) — Cloud Scheduler 매 24시간 호출.
# 등록만 되고 첫 /authorize 호출 없는 client 가 이 일수 초과 시 정리.
OAUTH_CLIENT_CLEANUP_AGE_DAYS=30
